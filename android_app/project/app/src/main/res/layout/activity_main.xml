<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView android:id="@+id/title"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Glucose Display"
            android:textAppearance="?attr/textAppearanceHeadlineSmall"
            android:paddingTop="8dp" />

        <TextView android:id="@+id/subtitle"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="" android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:paddingBottom="18dp" />

        <!-- ================= HOME ================= -->
        <LinearLayout android:id="@+id/stepHome"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:visibility="gone">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardCornerRadius="16dp" app:cardElevation="0dp"
                app:strokeWidth="1dp" app:strokeColor="?attr/colorOutlineVariant">
                <TextView android:id="@+id/homeStatus"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Checking device…"
                    android:textAppearance="?attr/textAppearanceBodyLarge"
                    android:padding="18dp" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton android:id="@+id/homeSetup"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="16dp" android:text="Set up / reconfigure" />

            <com.google.android.material.button.MaterialButton android:id="@+id/homeRefresh"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Refresh" />
        </LinearLayout>

        <!-- ================= NIGHTSCOUT ================= -->
        <LinearLayout android:id="@+id/stepNs"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:visibility="gone">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Step 1 of 4 · Your Nightscout"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="?attr/colorPrimary" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Do this on your normal internet, before joining the display."
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?attr/colorOnSurfaceVariant" android:paddingBottom="14dp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="Nightscout site URL">
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/nsUrl"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="textUri" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="8dp" android:hint="Access token">
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/nsToken"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView android:id="@+id/nsHelp"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Token: in Nightscout open the menu, then Admin Tools, then Subjects, add one with the readable role and copy its token. You can also paste a full URL that already contains ?token=…"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:paddingTop="6dp" android:paddingBottom="8dp" />

            <com.google.android.material.button.MaterialButton android:id="@+id/nsOpen"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Open my Nightscout ↗" />

            <com.google.android.material.card.MaterialCardView android:id="@+id/nsResultCard"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="8dp" android:visibility="gone"
                app:cardCornerRadius="14dp" app:cardElevation="0dp">
                <TextView android:id="@+id/nsResult"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="" android:padding="14dp"
                    android:textAppearance="?attr/textAppearanceBodyMedium" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton android:id="@+id/nsCheck"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="10dp" android:text="Check" />
            <com.google.android.material.button.MaterialButton android:id="@+id/nsNext"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Next" android:enabled="false" />
            <com.google.android.material.button.MaterialButton android:id="@+id/nsBack"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Back" />
        </LinearLayout>

        <!-- ================= CONNECT ================= -->
        <LinearLayout android:id="@+id/stepConnect"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:visibility="gone">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Step 2 of 4 · Connect to the display"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="?attr/colorPrimary" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Connect to the display's setup hotspot to send it your settings."
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?attr/colorOnSurfaceVariant" android:paddingBottom="14dp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:passwordToggleEnabled="true" android:hint="Hotspot password">
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/apPass"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="textPassword" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton android:id="@+id/connectAuto"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Connect to GlucoseSetup" app:icon="@android:drawable/stat_sys_data_bluetooth" />

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="— or join GlucoseSetup manually in your Wi-Fi settings (mobile data off) —"
                android:textAppearance="?attr/textAppearanceLabelSmall" android:gravity="center"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:paddingTop="14dp" android:paddingBottom="6dp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="Device address">
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/deviceAddr"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="192.168.4.1" android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.card.MaterialCardView android:id="@+id/connectStatusCard"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="8dp" android:visibility="gone"
                app:cardCornerRadius="14dp" app:cardElevation="0dp">
                <TextView android:id="@+id/connectStatus"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="" android:padding="14dp"
                    android:textAppearance="?attr/textAppearanceBodyMedium" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton android:id="@+id/connectFind"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="10dp" android:text="Find device" />
            <com.google.android.material.button.MaterialButton android:id="@+id/connectNext"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Next" android:enabled="false" />
            <com.google.android.material.button.MaterialButton android:id="@+id/connectBack"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Back" />
        </LinearLayout>

        <!-- ================= WIFI ================= -->
        <LinearLayout android:id="@+id/stepWifi"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:visibility="gone">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Step 3 of 4 · The display's Wi-Fi"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="?attr/colorPrimary" android:paddingBottom="8dp" />

            <com.google.android.material.button.MaterialButton android:id="@+id/wifiScan"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Scan networks the display can see" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Tap your network to enter its password."
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:paddingTop="8dp" android:paddingBottom="2dp" />

            <LinearLayout android:id="@+id/wifiList"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:paddingTop="4dp" android:paddingBottom="6dp" />

            <com.google.android.material.button.MaterialButton android:id="@+id/wifiBack"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Back" />
        </LinearLayout>

        <!-- ================= SENDING ================= -->
        <LinearLayout android:id="@+id/stepSending"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:gravity="center" android:visibility="gone">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:indeterminate="true" android:layout_marginTop="36dp"
                android:layout_marginBottom="18dp" />
            <TextView android:id="@+id/sendStatus"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Sending setup to the display…" android:gravity="center"
                android:textAppearance="?attr/textAppearanceBodyLarge" />
        </LinearLayout>

        <!-- ================= DONE ================= -->
        <LinearLayout android:id="@+id/stepDone"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:gravity="center" android:visibility="gone">

            <TextView android:id="@+id/doneStatus"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="" android:gravity="center" android:padding="20dp"
                android:textAppearance="?attr/textAppearanceTitleMedium" />
            <com.google.android.material.button.MaterialButton android:id="@+id/doneHome"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Done" />
        </LinearLayout>

        <TextView android:id="@+id/log"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="" android:textColor="?attr/colorOnSurfaceVariant"
            android:textAppearance="?attr/textAppearanceBodySmall" android:paddingTop="20dp" />

    </LinearLayout>
</ScrollView>
